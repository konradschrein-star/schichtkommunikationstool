# Database
DATABASE_URL=postgresql://user:password@localhost:5432/shiftsync

# Encryption (für API Keys - 32 bytes base64)
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=your-base64-encoded-32-byte-key-here

# Fast-Whisper Service
WHISPER_SERVICE_URL=http://localhost:8000

# Data Root (absolute path)
DATA_ROOT_PATH=/var/shiftsync/data

# Default LLM (Fallback wenn User keinen eigenen Key hat)
DEFAULT_LLM_PROVIDER=anthropic
DEFAULT_LLM_API_KEY=sk-ant-api-key-here

# Optional: Alternative Providers
OPENAI_API_KEY=sk-proj-api-key-here
GEMINI_API_KEY=api-key-here
