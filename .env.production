# Schichtkommunikationstool - Production Environment
# Kopiere diese Datei nach .env auf dem Server und fülle die Werte aus

# === Node Environment ===
NODE_ENV=production
PORT=3069

# === Database ===
# PostgreSQL läuft in Docker auf Port 5433 (isoliert von Content Forge auf 5432)
DATABASE_URL=postgresql://postgres:schichtkommunikations_secure_pw_2026@localhost:5433/schichtkommunikationstool

# === Whisper Service ===
# Läuft in Docker auf Port 8005
WHISPER_SERVICE_URL=http://localhost:8005

# === Data Storage ===
DATA_ROOT_PATH=/opt/schichtkommunikationstool/data

# === Encryption ===
# Generiere mit: openssl rand -base64 32
# WICHTIG: Ersetze mit deinem echten Schlüssel!
ENCRYPTION_KEY=REPLACE_WITH_YOUR_BASE64_ENCRYPTION_KEY

# === LLM Provider ===
# Wird später auch in der Datenbank gespeichert
DEFAULT_LLM_PROVIDER=anthropic
DEFAULT_LLM_API_KEY=REPLACE_WITH_YOUR_ANTHROPIC_API_KEY

# === Docker Compose (PostgreSQL Password) ===
POSTGRES_PASSWORD=schichtkommunikations_secure_pw_2026
